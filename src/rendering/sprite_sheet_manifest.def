// Cheffy (farmer) uses two sprite variants: empty while seeking/gathering,
// full while returning/depositing. Idle and attack share a single authored
// idle sheet per variant; the attack clip is reused as a one-shot
// gather/deposit work animation.
SPRITE_SHEET(farmer_idle,        false, SPRITE_TYPE_FARMER,      ANIM_IDLE,   "src/assets/characters/Farmer/cheffy_idle_empty.png", 4, 1, true)
SPRITE_SHEET(farmer_walk,        false, SPRITE_TYPE_FARMER,      ANIM_WALK,   "src/assets/characters/Farmer/cheffy_walk_empty.png", 8, 1, true)
SPRITE_SHEET(farmer_hurt,        false, SPRITE_TYPE_FARMER,      ANIM_HURT,   "src/assets/characters/Farmer/hurt.png",              4, 3, true)
SPRITE_SHEET(farmer_attack,      false, SPRITE_TYPE_FARMER,      ANIM_ATTACK, "src/assets/characters/Farmer/cheffy_idle_empty.png", 4, 1, true)

