SPRITE_SHEET(farmer_full_hurt,   false, SPRITE_TYPE_FARMER_FULL, ANIM_HURT,   "src/assets/characters/Farmer/hurt.png",              4, 3, true)
SPRITE_SHEET(farmer_full_attack, false, SPRITE_TYPE_FARMER_FULL, ANIM_ATTACK, "src/assets/characters/Farmer/cheffy_idle_full.png",  4, 1, true)

